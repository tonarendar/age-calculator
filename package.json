{
  "name": "age-calculator",
  "version": "1.0.0",
  "description": "A TypeScript app to calculate age from birthdate with UI and Playwright tests",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node src/app.ts",
    "test:unit": "jest",
    "test:functional": "playwright test tests/functional/*.spec.ts --project=chromium",
    "test:cross-browser": "playwright test tests/functional/*.spec.ts --project=chromium --project=firefox",
    "test:api": "playwright test tests/api-tests/*.spec.ts --project=api-tests",
    "test:visual": "playwright test tests/visual/*.spec.ts --project=chromium",
    "test:accessibility": "playwright test tests/accessibility/*.spec.ts --project=chromium",
    "test:performance": "TODO: Placeholder for performance testing script",
    "test:ui": "playwright test tests/functional tests/visual tests/api-tests tests/accessibility --ui",
    "security:audit": "npm audit",
    "security:audit:fix": "npm audit fix",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"

  },
  "keywords": [
    "typescript",
    "playwright",
    "qa",
    "automation"
  ],
  "author": "Narendar",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.42.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
